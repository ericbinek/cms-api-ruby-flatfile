PORT=3016
DATA_DIR=./data

# First-run bootstrap: when the account store is empty, an admin account
# is created from these on startup. Set a real password before first run.
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# Per-IP request limits in a sliding one-minute window. Reads cover GET/HEAD,
# writes cover POST/PUT/DELETE. Exceeding a limit returns 429 with Retry-After.
RATE_LIMIT_READ_PER_MINUTE=600
RATE_LIMIT_WRITE_PER_MINUTE=60
